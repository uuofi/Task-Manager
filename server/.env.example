# ==============================================================================
# TaskControl API — Environment Variables
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# ==============================================================================

# --- Server ---
NODE_ENV=development
# Note: on Windows, port 5000 is often reserved — 5050 avoids EACCES.
PORT=5050
API_PREFIX=/api/v1

# --- Client (CORS) ---
# Comma-separated list of allowed origins.
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017/taskcontrol

# --- JWT ---
# Use long, random strings (e.g. `openssl rand -hex 64`). Keep these distinct.
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Password reset token lifetime (minutes)
RESET_TOKEN_EXPIRES_MIN=30

# --- Cookies ---
COOKIE_SECRET=change_me_cookie_secret

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# --- File storage ---
# Driver: local | cloudinary | s3  (only `local` implemented initially)
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# --- Email (SMTP) ---
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TaskControl <no-reply@taskcontrol.app>"

# --- Logging ---
LOG_LEVEL=info
