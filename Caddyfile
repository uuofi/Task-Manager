# TaskControl edge proxy.
# Caddy terminates TLS (automatic Let's Encrypt certificates for SITE_ADDRESS)
# and is the only container published to the internet.
#
# Set SITE_ADDRESS to `:80` instead of a hostname to run plain HTTP locally.

{
	email {$ACME_EMAIL}
}

{$SITE_ADDRESS} {
	encode zstd gzip

	# The API, the uploaded files and the Socket.IO handshake/websocket all live
	# on the Node server. Everything else is the React SPA. Keeping them on one
	# origin is what lets the client use its "/api/v1" + same-origin defaults and
	# keeps the refresh-token cookie first-party.
	@backend path /api/* /uploads/* /socket.io/*
	reverse_proxy @backend server:5050

	reverse_proxy client:80

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format console
	}
}
