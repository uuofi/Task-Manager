# Client environment variables (Vite — must be prefixed with VITE_).
# In development these can be left empty; vite.config.js proxies /api and
# /socket.io to the backend at http://localhost:5050.
# Absolute API base URL (e.g. https://api.taskcontrol.app/api/v1).
# Leave empty to use the dev proxy ("/api/v1").
VITE_API_URL=
# Socket.IO server URL. Leave empty to use same-origin (dev proxy).
VITE_SOCKET_URL=