# ==============================================================================
# TaskControl — production deployment (docker-compose.yml)
#
# Copy to `.env` on the SERVER, at /opt/taskcontrol/.env, and fill in.
# This one file feeds both docker compose and the server container (env_file).
# NEVER commit the real `.env` — CI/CD does not touch it.
#
#   cp .env.example .env && chmod 600 .env
# ==============================================================================

# --- Edge / TLS ---------------------------------------------------------------
# TLS + host routing are handled by an EXTERNAL reverse proxy (the hosting
# control panel), not by this stack. Point it at the published container ports:
#   https://taskat.site      -> 127.0.0.1:8080  (client)
#   https://api.taskat.site  -> 127.0.0.1:5050  (server)
# The SPA is built to call the API at https://api.taskat.site (see the client
# image build args, VITE_API_URL / VITE_SOCKET_URL, in .github/workflows).

# --- Images -------------------------------------------------------------------
# Must be lowercase. Compose appends `-server` / `-client`.
GHCR_REPO=ghcr.io/uuofi/task-manager
# Overridden by the deploy workflow with the commit SHA; `latest` for manual runs.
IMAGE_TAG=latest

# --- Database / cache credentials ---------------------------------------------
# IMPORTANT: use alphanumeric passwords only. These are interpolated into
# connection URIs, where @ : / ? # would be parsed as URI syntax and break auth.
# Generate with: openssl rand -hex 24
MONGO_ROOT_USER=taskcontrol
MONGO_ROOT_PASSWORD=change_me_alphanumeric_only
MONGO_DB=taskcontrol
REDIS_PASSWORD=change_me_alphanumeric_only

# NOTE: MONGODB_URI and REDIS_URL are assembled from the values above inside
# docker-compose.yml — do not set them here.

# --- App ----------------------------------------------------------------------
# Must be `production` so auth cookies are sent Secure + SameSite=None, which is
# REQUIRED for the split-domain setup (SPA and API on different origins).
NODE_ENV=production
# The public HTTPS origin of the FRONTEND (taskat.site) — used in invitation /
# reset email links.
CLIENT_URL=https://taskat.site
# Browser origin(s) allowed to call the API (REST + Socket.IO). This is the
# FRONTEND origin, NOT the api subdomain. Add www here too if you serve it.
CORS_ORIGINS=https://taskat.site

# --- JWT / cookies ------------------------------------------------------------
# Generate each separately: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RESET_TOKEN_EXPIRES_MIN=30
COOKIE_SECRET=change_me_cookie_secret

# --- Rate limiting ------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
CONTACT_RATE_LIMIT_MAX=5

# --- File storage -------------------------------------------------------------
# `local` writes into /app/uploads, backed by the `uploads` docker volume.
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# --- Email (SMTP) -------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TaskControl <no-reply@taskcontrol.example.com>"

# --- Telegram (contact form) --------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=info
