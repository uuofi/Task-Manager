# ==============================================================================
# TaskControl — production deployment (docker-compose.yml)
#
# Copy to `.env` on the SERVER, at /opt/taskcontrol/.env, and fill in.
# This one file feeds both docker compose and the server container (env_file).
# NEVER commit the real `.env` — CI/CD does not touch it.
#
#   cp .env.example .env && chmod 600 .env
# ==============================================================================

# --- Edge / TLS ---------------------------------------------------------------
# The public domain. Its DNS A/AAAA record must already point at this server —
# Caddy requests a Let's Encrypt certificate for it on first start.
# Use `:80` instead to run plain HTTP without a domain.
SITE_ADDRESS=taskcontrol.example.com
# Used by Let's Encrypt for expiry notices.
ACME_EMAIL=you@example.com

# --- Images -------------------------------------------------------------------
# Must be lowercase. Compose appends `-server` / `-client`.
GHCR_REPO=ghcr.io/uuofi/task-manager
# Overridden by the deploy workflow with the commit SHA; `latest` for manual runs.
IMAGE_TAG=latest

# --- Database / cache credentials ---------------------------------------------
# IMPORTANT: use alphanumeric passwords only. These are interpolated into
# connection URIs, where @ : / ? # would be parsed as URI syntax and break auth.
# Generate with: openssl rand -hex 24
MONGO_ROOT_USER=taskcontrol
MONGO_ROOT_PASSWORD=change_me_alphanumeric_only
MONGO_DB=taskcontrol
REDIS_PASSWORD=change_me_alphanumeric_only

# NOTE: MONGODB_URI and REDIS_URL are assembled from the values above inside
# docker-compose.yml — do not set them here.

# --- App ----------------------------------------------------------------------
NODE_ENV=production
# Must be the public HTTPS origin: used in invitation/reset emails and enforced
# by the API's CORS allowlist.
CLIENT_URL=https://taskcontrol.example.com
CORS_ORIGINS=https://taskcontrol.example.com

# --- JWT / cookies ------------------------------------------------------------
# Generate each separately: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RESET_TOKEN_EXPIRES_MIN=30
COOKIE_SECRET=change_me_cookie_secret

# --- Rate limiting ------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
CONTACT_RATE_LIMIT_MAX=5

# --- File storage -------------------------------------------------------------
# `local` writes into /app/uploads, backed by the `uploads` docker volume.
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# --- Email (SMTP) -------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TaskControl <no-reply@taskcontrol.example.com>"

# --- Telegram (contact form) --------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=info
